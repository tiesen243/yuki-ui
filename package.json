{
  "name": "yuki-ui",
  "private": true,
  "homepage": "https://ui.tiesen.id.vn",
  "bugs": {
    "url": "https://github.com/tiesen243/yuki-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiesen243/yuki-ui.git"
  },
  "workspaces": [
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "build": "bun turbo --filter @yuki/web build",
    "clean": "bun --filter '*' clean && git clean -xdf node_modules",
    "dev": "bun --filter @yuki/web dev",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun --filter '*' typescheck"
  },
  "devDependencies": {
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5"
  },
  "packageManager": "bun@1.3.0",
  "catalogs": {
    "prod": {
      "@tanstack/react-query": "^5.90.12",
      "zod": "4.4.3"
    },
    "dev": {
      "@types/node": "^26.1.1",
      "dotenv-cli": "^11.0.0",
      "tsdown": "^0.19.0-beta.5",
      "typescript": "^6.0.3"
    },
    "react": {
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "react": "^19.2.7",
      "react-dom": "^19.2.7"
    },
    "tailwind": {
      "@tailwindcss/postcss": "^4.3.3",
      "@tailwindcss/vite": "^4.1.18",
      "tailwindcss": "^4.3.3"
    }
  }
}
