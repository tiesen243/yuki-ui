{
  "extends": "@yuki/tsconfig/react-package.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "fumadocs-mdx:collections/*": ["./.source/*"],
      "@/*": ["./*"],
      "@/server/auth/*": ["./registry/auth/server/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".source/*.ts"
  ]
}
