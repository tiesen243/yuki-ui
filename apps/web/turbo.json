{
  "$schema": "../../node_modules/turbo/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["build:shadcn"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "next-env.d.ts"
      ]
    },
    "build:shadcn": {
      "dependsOn": ["build:registry"],
      "outputs": ["public/r/**"]
    },
    "build:registry": {
      "outputs": ["__registry__/**"]
    },
    "dev": {
      "dependsOn": ["^build"]
    }
  }
}
