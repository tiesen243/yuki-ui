{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "name": "Yuki UI",
  "short_name": "yuki-ui",
  "description": "A comprehensive collection of accessible, customizable components built with React, TypeScript, and Tailwind CSS. Install with a single command.",
  "dir": "ltr",
  "lang": "en",
  "icons": [
    { "src": "/favicon.ico", "type": "image/x-icon", "sizes": "16x16 32x32" },
    { "src": "/icon-192.png", "type": "image/png", "sizes": "192x192" },
    { "src": "/icon-512.png", "type": "image/png", "sizes": "512x512" },
    {
      "src": "/icon-192-maskable.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "/icon-512-maskable.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ]
}
