{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "clean": "git clean -xdf .cache .next .source .turbo __registry__ node_modules",
    "dev": "next dev",
    "postinstall": "fumadocs-mdx",
    "start": "next start",
    "typescheck": "fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@orama/orama": "^3.1.18",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.7.14",
    "fumadocs-mdx": "14.2.13",
    "fumadocs-ui": "16.7.14",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:tailwind",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@yuki/tsconfig": "workspace:*",
    "alchemy": "^0.91.2",
    "postcss": "^8.5.9",
    "tailwindcss": "catalog:tailwind",
    "typescript": "catalog:dev",
    "wrangler": "^4.82.2"
  }
}
