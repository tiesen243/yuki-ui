{
  "name": "@yuki/kaze",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --env-file ../.env next build",
    "build:registry": "bun run scripts/build-registry.ts",
    "build:shadcn": "bunx --bun shadcn build __registry__/registry.autogenerated.json",
    "clean": "git clean -xdf .cache .next .source .turbo __registry__ node_modules",
    "dev": "bun --env-file ../.env next dev",
    "postinstall": "fumadocs-mdx",
    "start": "bun --env-file ../.env next start",
    "typecheck": "bun --env-file ../.env next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "arktype": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.7.9",
    "fumadocs-mdx": "^14.2.11",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.7.9",
    "lucide-react": "^1.7.0",
    "marked": "^17.0.5",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "tailwind-merge": "^3.5.0",
    "valibot": "^1.3.1",
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:tailwind",
    "@types/mdx": "^2.0.13",
    "@types/node": "catalog:dev",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@yuki/tsconfig": "workspace:*",
    "shadcn": "^4.1.2",
    "tailwindcss": "catalog:tailwind",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:dev"
  }
}
